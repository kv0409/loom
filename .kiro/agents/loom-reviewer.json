{
  "name": "loom-reviewer",
  "description": "Loom reviewer \u2014 reviews code changes in worktrees. Read-only, no write tool.",
  "model": "claude-opus-4.6",
  "tools": [
    "read",
    "grep",
    "glob",
    "code",
    "shell",
    "thinking",
    "todo"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "thinking",
    "todo",
    "@loom/loom_*"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        ".*"
      ],
      "deniedCommands": [
        "rm -rf /.*",
        "rm -rf ~.*",
        "rm -rf \\*",
        "git push.*",
        "git push --force.*",
        "git reset --hard.*",
        "git clean -fdx.*",
        "chmod -R 777.*",
        "sudo .*",
        "shutdown.*",
        "reboot.*",
        "kill -9 -1",
        "killall.*",
        "mkfs.*",
        "dd if=.*"
      ]
    }
  },
  "mcpServers": {
    "loom": {
      "command": "loom",
      "args": [
        "mcp-server"
      ]
    }
  },
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo \"=== LOOM AGENT: $LOOM_AGENT_ID ===\" && echo \"Role: reviewer\" && echo \"Root: $LOOM_ROOT\"",
        "timeout_ms": 3000
      },
      {
        "command": "cd $LOOM_WORKTREE 2>/dev/null && git diff --stat || echo 'No worktree set'",
        "timeout_ms": 5000
      }
    ],
    "agentStop": [
      {
        "command": ".kiro/hooks/loom-stop-hook.sh",
        "timeout_ms": 5000
      }
    ]
  },
  "prompt": "file://prompts/loom-reviewer.md",
  "resources": [
    "file://README.md",
    "file://docs/ARCHITECTURE.md",
    "file://.kiro/steering/**/*.md"
  ]
}
