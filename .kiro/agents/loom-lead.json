{
  "name": "loom-lead",
  "description": "Loom lead — coordinates builders, merges worktrees, reports to orchestrator.",
  "model": "claude-opus-4.6",
  "tools": [
    "read",
    "grep",
    "glob",
    "code",
    "shell",
    "thinking",
    "todo"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "thinking",
    "todo",
    "@loom/loom_*"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        ".*"
      ],
      "deniedCommands": [
        "rm -rf /.*",
        "rm -rf ~.*",
        "rm -rf \\*",
        "git push.*",
        "git push --force.*",
        "git reset --hard.*",
        "git clean -fdx.*",
        "chmod -R 777.*",
        "sudo .*",
        "shutdown.*",
        "reboot.*",
        "kill -9 -1",
        "killall.*",
        "mkfs.*",
        "dd if=.*"
      ]
    }
  },
  "mcpServers": {
    "loom": {
      "command": "loom",
      "args": [
        "mcp-server"
      ]
    }
  },
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo \"=== LOOM AGENT: $LOOM_AGENT_ID ===\" && echo \"Role: lead\" && echo \"Root: $LOOM_ROOT\"",
        "timeout_ms": 3000
      },
      {
        "command": "loom issue list --assignee $LOOM_AGENT_ID 2>/dev/null || echo 'No assigned issues'",
        "timeout_ms": 5000
      },
      {
        "command": "loom agents 2>/dev/null || echo 'No agents yet'",
        "timeout_ms": 5000
      }
    ],
    "stop": [
      {
        "command": ".kiro/hooks/loom-stop-hook.sh",
        "timeout_ms": 5000
      }
    ],
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "loom agent heartbeat 2>/dev/null",
        "description": "Heartbeat on tool use",
        "timeout_ms": 2000
      }
    ]
  },
  "prompt": "file://prompts/loom-lead.md",
  "resources": [
    "file://README.md",
    "file://docs/ARCHITECTURE.md",
    "file://.kiro/steering/**/*.md"
  ]
}
