{
  "name": "loom-explorer",
  "description": "Loom explorer \u2014 read-only codebase exploration and analysis.",
  "model": "claude-haiku-4.5",
  "tools": [
    "read",
    "grep",
    "glob",
    "code",
    "shell",
    "thinking"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "thinking",
    "@loom/loom_*"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        ".*"
      ],
      "deniedCommands": [
        "rm -rf /.*",
        "rm -rf ~.*",
        "rm -rf \\*",
        "git push.*",
        "git push --force.*",
        "git reset --hard.*",
        "git clean -fdx.*",
        "chmod -R 777.*",
        "sudo .*",
        "shutdown.*",
        "reboot.*",
        "kill -9 -1",
        "killall.*",
        "mkfs.*",
        "dd if=.*"
      ]
    }
  },
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo \"=== LOOM AGENT: $LOOM_AGENT_ID ===\" && echo \"Role: explorer\" && echo \"Root: $LOOM_ROOT\"",
        "timeout_ms": 3000
      },
      {
        "command": "tree -L 3 -I 'node_modules|.git|dist|build|vendor' --dirsfirst 2>/dev/null || find . -maxdepth 3 -type d | head -50",
        "timeout_ms": 5000
      }
    ],
    "agentStop": [
      {
        "command": ".kiro/hooks/loom-stop-hook.sh",
        "timeout_ms": 5000
      }
    ]
  },
  "prompt": "file://prompts/loom-explorer.md",
  "resources": [
    "file://README.md"
  ]
}
