{
  "name": "loom-explorer",
  "description": "Loom explorer \u2014 read-only codebase exploration and analysis.",
  "model": "claude-haiku-4.5",
  "tools": [
    "read",
    "grep",
    "glob",
    "code",
    "shell",
    "thinking"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "thinking",
    "@loom/loom_*"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        ".*"
      ],
      "deniedCommands": [
        "chmod -R 777.*",
        "dd if=.*",
        "git branch --delete.*",
        "git branch -[dD].*",
        "git checkout main.*",
        "git checkout master.*",
        "git clean -fdx.*",
        "git merge.*",
        "git push --force.*",
        "git push.*",
        "git reset --hard.*",
        "git switch main.*",
        "git switch master.*",
        "git worktree prune.*",
        "git worktree remove.*",
        "kill -9 -1",
        "killall.*",
        "mkfs.*",
        "reboot.*",
        "rm -rf /.*",
        "rm -rf \\*",
        "rm -rf ~.*",
        "shutdown.*",
        "sudo .*"
      ]
    }
  },
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo \"=== LOOM AGENT: $LOOM_AGENT_ID ===\" && echo \"Role: explorer\" && echo \"Root: $LOOM_ROOT\"",
        "timeout_ms": 3000
      },
      {
        "command": "tree -L 3 -I 'node_modules|.git|dist|build|vendor' --dirsfirst 2>/dev/null || find . -maxdepth 3 -type d | head -50",
        "timeout_ms": 5000
      }
    ],
    "postToolUse": [
      {
        "matcher": "*",
        "command": ".kiro/hooks/loom-tool-logger.sh",
        "description": "Log tool calls to .loom/agents/${LOOM_AGENT_ID}.tools"
      }
    ],
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "loom agent heartbeat 2>/dev/null",
        "description": "Heartbeat on tool use",
        "timeout_ms": 2000
      }
    ]
  },
  "prompt": "file://prompts/loom-explorer.md",
  "resources": [
    "file://README.md",
    "skill://.kiro/skills/**/SKILL.md"
  ]
}
