{
  "name": "loom-researcher",
  "description": "Loom researcher — external research via web search and fetch. No code writing.",
  "model": "claude-sonnet-4.6",
  "tools": [
    "read",
    "grep",
    "glob",
    "shell",
    "thinking",
    "web_search",
    "web_fetch"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "thinking",
    "web_search",
    "web_fetch",
    "@loom/loom_*"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "denyByDefault": true,
      "allowedCommands": [
        "loom .*"
      ],
      "deniedCommands": [
        ".*>.*",
        ".*>>.*",
        "rm.*",
        "mv.*",
        "cp.*"
      ]
    }
  },
  "mcpServers": {
    "loom": {
      "command": "loom",
      "args": [
        "mcp-server"
      ]
    }
  },
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo \"=== LOOM AGENT: $LOOM_AGENT_ID ===\" && echo \"Role: researcher\" && echo \"Root: $LOOM_ROOT\"",
        "timeout_ms": 3000
      }
    ]
  },
  "prompt": "file://prompts/loom-researcher.md",
  "resources": []
}
