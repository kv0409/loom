{
  "name": "loom-lead",
  "description": "Loom lead — coordinates builders, merges worktrees, reports to orchestrator.",
  "model": "claude-sonnet-4.6",
  "tools": ["read", "grep", "glob", "code", "shell", "thinking", "todo"],
  "allowedTools": ["read", "grep", "glob", "code", "thinking", "todo"],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        "loom .*",
        "git (status|log|diff|show|branch|blame)( .*)?",
        "git merge --squash.*",
        "git commit.*",
        "ls( .*)?",
        "cat( .*)?",
        "find( .*)?",
        "head( .*)?",
        "tail( .*)?"
      ],
      "deniedCommands": [
        "rm .*",
        "git push.*",
        "git checkout (main|master).*",
        ".*>.*",
        ".*>>.*"
      ]
    }
  },
  "mcpServers": {
    "loom": {
      "command": "loom",
      "args": ["mcp-server"]
    }
  },
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo \"=== LOOM AGENT: $LOOM_AGENT_ID ===\" && echo \"Role: lead\" && echo \"Root: $LOOM_ROOT\"",
        "timeout_ms": 3000
      },
      {
        "command": "loom issue list --assignee $LOOM_AGENT_ID 2>/dev/null || echo 'No assigned issues'",
        "timeout_ms": 5000
      },
      {
        "command": "loom agents 2>/dev/null || echo 'No agents yet'",
        "timeout_ms": 5000
      }
    ]
  },
  "prompt": "file://.loom/templates/lead.md",
  "resources": []
}
