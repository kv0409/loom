{
  "name": "loom-lead",
  "description": "Loom lead — coordinates builders, merges worktrees, reports to orchestrator.",
  "model": "claude-opus-4.7",
  "tools": [
    "read",
    "grep",
    "glob",
    "code",
    "shell",
    "thinking",
    "todo"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "thinking",
    "todo",
    "@loom/loom_*"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        ".*"
      ],
      "deniedCommands": [
        "chmod -R 777.*",
        "dd if=.*",
        "git branch --delete.*",
        "git branch -[dD].*",
        "git checkout main.*",
        "git checkout master.*",
        "git clean -fdx.*",
        "git merge.*",
        "git push --force.*",
        "git push.*",
        "git reset --hard.*",
        "git switch main.*",
        "git switch master.*",
        "git worktree prune.*",
        "git worktree remove.*",
        "kill -9 -1",
        "killall.*",
        "mkfs.*",
        "reboot.*",
        "rm -rf /.*",
        "rm -rf \\*",
        "rm -rf ~.*",
        "shutdown.*",
        "sudo .*"
      ]
    }
  },
  "mcpServers": {
    "loom": {
      "command": "loom",
      "args": [
        "mcp-server"
      ]
    }
  },
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo \"=== LOOM AGENT: $LOOM_AGENT_ID ===\" && echo \"Role: lead\" && echo \"Root: $LOOM_ROOT\"",
        "timeout_ms": 3000
      },
      {
        "command": "loom issue list --assignee $LOOM_AGENT_ID 2>/dev/null || echo 'No assigned issues'",
        "timeout_ms": 5000
      },
      {
        "command": "loom agents 2>/dev/null || echo 'No agents yet'",
        "timeout_ms": 5000
      },
      {
        "command": "./loom --help",
        "description": "Show available loom CLI commands",
        "timeout_ms": 5000
      }
    ],
    "preToolUse": [
      {
        "matcher": "*",
        "command": "loom agent heartbeat 2>/dev/null",
        "description": "Heartbeat on tool use",
        "timeout_ms": 2000
      }
    ]
  },
  "prompt": "file://prompts/loom-lead.md",
  "resources": [
    "file://README.md",
    "file://docs/ARCHITECTURE.md",
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/**/SKILL.md",
    "skill://~/.kiro/skills/**/SKILL.md"
  ]
}
